generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"] 
}

datasource db {
  provider = "postgresql" 
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  wallets   Wallet[]
  snapshots PortfolioSnapshot[]
  analyses  AIAnalysis[]
  alerts    Alert[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Wallet {
  id        String   @id @default(cuid())
  address   String   @unique
  chainId   Int      @default(1)
  userId    String
  label     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots PortfolioSnapshot[]

  @@index([userId])
}

model PortfolioSnapshot {
  id         String   @id @default(cuid())
  userId     String
  walletId   String
  totalValue Decimal  @db.Decimal(18, 8)
  totalYield Decimal  @db.Decimal(18, 8) @default(0)
  gasSpent   Decimal  @db.Decimal(18, 8) @default(0)
  positions  Json
  prices     Json
  snapshotAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId, snapshotAt])
  @@index([walletId, snapshotAt])
}

model AIAnalysis {
  id           String   @id @default(cuid())
  userId       String
  prompt       String   @db.Text
  response     String   @db.Text
  model        String   @default("gemini-1.5-flash")
  positionsCtx Json?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Alert {
  id        String    @id @default(cuid())
  userId    String
  type      AlertType
  threshold Decimal   @db.Decimal(18, 8)
  asset     String?
  protocol  String?
  isActive  Boolean   @default(true)
  triggered Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum AlertType {
  PRICE_ABOVE
  PRICE_BELOW
  HEALTH_FACTOR_LOW
  YIELD_THRESHOLD
}